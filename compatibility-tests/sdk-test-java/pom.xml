<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.floci.az</groupId>
    <artifactId>sdk-test-java</artifactId>
    <version>1.0.0-SNAPSHOT</version>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <azure.sdk.bom.version>1.2.28</azure.sdk.bom.version>
        <junit.version>5.10.2</junit.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.azure</groupId>
                <artifactId>azure-sdk-bom</artifactId>
                <version>${azure.sdk.bom.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-storage-blob</artifactId>
        </dependency>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-storage-queue</artifactId>
        </dependency>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-data-tables</artifactId>
        </dependency>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-data-appconfiguration</artifactId>
        </dependency>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-cosmos</artifactId>
        </dependency>
        <dependency>
            <groupId>com.azure</groupId>
            <artifactId>azure-security-keyvault-secrets</artifactId>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.qpid</groupId>
            <artifactId>qpid-jms-client</artifactId>
            <version>2.4.0</version>
            <scope>test</scope>
            <exclusions>
                <!-- Exclude qpid's older Netty so the Azure SDK BOM version wins -->
                <exclusion>
                    <groupId>io.netty</groupId>
                    <artifactId>*</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-nop</artifactId>
            <version>2.0.13</version>
            <scope>test</scope>
        </dependency>
        <!-- MongoDB -->
        <dependency>
            <groupId>org.mongodb</groupId>
            <artifactId>mongodb-driver-sync</artifactId>
            <version>5.1.0</version>
            <scope>test</scope>
        </dependency>
        <!-- PostgreSQL JDBC -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.7.3</version>
            <scope>test</scope>
        </dependency>
        <!-- Cassandra / ScyllaDB -->
        <dependency>
            <groupId>com.datastax.oss</groupId>
            <artifactId>java-driver-core</artifactId>
            <version>4.17.0</version>
            <scope>test</scope>
        </dependency>
        <!-- Gremlin -->
        <dependency>
            <groupId>org.apache.tinkerpop</groupId>
            <artifactId>gremlin-driver</artifactId>
            <version>3.7.1</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <!--
                      Pass SSL + emulator cert config as JVM -D args so they are applied
                      before ANY class is loaded (earlier than systemPropertyVariables).
                      - noOpenSsl: forces Netty to use the JDK SSL provider, which respects
                        javax.net.ssl.* properties (the native BoringSSL engine ignores them).
                      - trustStore: the emulator's self-signed PKCS12, bundled in test resources
                        so it is present both locally and inside the CI Docker image. The cert
                        has SANs for "localhost" (local dev) and "floci-az" (CI Docker service).
                    -->
                    <argLine>
                        --enable-native-access=ALL-UNNAMED
                        -Dio.netty.handler.ssl.noOpenSsl=true
                        -Djavax.net.ssl.trustStore=${project.basedir}/src/test/resources/floci-az.p12
                        -Djavax.net.ssl.trustStorePassword=floci-az
                        -Djavax.net.ssl.trustStoreType=PKCS12
                    </argLine>
                    <!--
                      Engine tests require Docker + a specially configured emulator instance.
                      They are excluded from the default 'mvn test' run and executed instead
                      via dedicated Makefile targets (make test-cosmos-all, etc.) that start
                      the emulator with each engine enabled, run the test, then stop it.
                      The '-Dtest=CosmosXxxEngineCompatibilityTest' flag used by those targets
                      overrides this exclusion automatically.
                    -->
                    <excludes>
                        <exclude>**/*EngineCompatibilityTest.java</exclude>
                    </excludes>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>